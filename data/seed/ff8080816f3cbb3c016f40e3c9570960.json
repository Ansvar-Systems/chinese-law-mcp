{
  "id": "ff8080816f3cbb3c016f40e3c9570960",
  "type": "administrative_regulation",
  "title": "中华人民共和国国库券条例",
  "title_en": "",
  "short_name": "",
  "status": "in_force",
  "issued_date": "2011-01-08",
  "in_force_date": null,
  "url": "https://flk.npc.gov.cn/detail?bbbs=ff8080816f3cbb3c016f40e3c9570960",
  "category_code": 210,
  "category_name": "行政法规 (Administrative Regulations)",
  "issuing_body": "国务院",
  "provisions": [
    {
      "provision_ref": "1",
      "chapter": "",
      "section": "1",
      "title": "",
      "content": "为了筹集社会资金，进行社会主义现代化建设，制定本条例。",
      "language": "zh"
    },
    {
      "provision_ref": "2",
      "chapter": "",
      "section": "2",
      "title": "",
      "content": "国库券的发行对象是：居民个人、个体工商户、企业、事业单位、机关、社会团体和其他组织。",
      "language": "zh"
    },
    {
      "provision_ref": "3",
      "chapter": "",
      "section": "3",
      "title": "",
      "content": "国库券以人民币元为计算单位。",
      "language": "zh"
    },
    {
      "provision_ref": "4",
      "chapter": "",
      "section": "4",
      "title": "",
      "content": "每年国库券的发行数额、利率、偿还期等，经国务院确定后，由财政部予以公告。",
      "language": "zh"
    },
    {
      "provision_ref": "5",
      "chapter": "",
      "section": "5",
      "title": "",
      "content": "国库券发行采取承购包销、认购等方式。\n国家下达的国库券发行计划，应当按期完成。",
      "language": "zh"
    },
    {
      "provision_ref": "6",
      "chapter": "",
      "section": "6",
      "title": "",
      "content": "国库券按期偿还本金。国库券利息在偿还本金时一次付给，不计复利。",
      "language": "zh"
    },
    {
      "provision_ref": "7",
      "chapter": "",
      "section": "7",
      "title": "",
      "content": "国库券的发行和还本付息事宜，在各级人民政府统一领导下，由财政部门和中国人民银行组织有关部门多渠道办理。",
      "language": "zh"
    },
    {
      "provision_ref": "8",
      "chapter": "",
      "section": "8",
      "title": "",
      "content": "国库券可以用于抵押，但是不得作为货币流通。",
      "language": "zh"
    },
    {
      "provision_ref": "9",
      "chapter": "",
      "section": "9",
      "title": "",
      "content": "国库券可以转让，但是应当在国家批准的交易场所办理。",
      "language": "zh"
    },
    {
      "provision_ref": "10",
      "chapter": "",
      "section": "10",
      "title": "",
      "content": "发行国库券筹集的资金，由国务院统一安排使用。",
      "language": "zh"
    },
    {
      "provision_ref": "11",
      "chapter": "",
      "section": "11",
      "title": "",
      "content": "对伪造国库券的，依法追究刑事责任。\n对倒卖国库券的，按照投机倒把论处。(2011年1月8日删除)",
      "language": "zh"
    },
    {
      "provision_ref": "12",
      "chapter": "",
      "section": "12",
      "title": "",
      "content": "国库券的利息收入享受免税待遇。",
      "language": "zh"
    },
    {
      "provision_ref": "13",
      "chapter": "",
      "section": "13",
      "title": "",
      "content": "本条例由财政部负责解释。实施细则由财政部商中国人民银行制定。",
      "language": "zh"
    },
    {
      "provision_ref": "14",
      "chapter": "",
      "section": "14",
      "title": "",
      "content": "本条例自发布之日起施行。",
      "language": "zh"
    }
  ],
  "definitions": [],
  "eu_references": []
}