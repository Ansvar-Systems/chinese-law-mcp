{
  "id": "ff8080816f3cbb3c016f40970a7804e9",
  "type": "administrative_regulation",
  "title": "国务院关于在香港特别行政区同时升挂使用国旗区旗的规定",
  "title_en": "",
  "short_name": "",
  "status": "in_force",
  "issued_date": "1997-06-05",
  "in_force_date": null,
  "url": "https://flk.npc.gov.cn/detail?bbbs=ff8080816f3cbb3c016f40970a7804e9",
  "category_code": 210,
  "category_name": "行政法规 (Administrative Regulations)",
  "issuing_body": "国务院",
  "provisions": [
    {
      "provision_ref": "1",
      "chapter": "",
      "section": "1",
      "title": "",
      "content": "凡国旗和区旗同时升挂、使用时，应当将国旗置于中心、较高或者突出的位置。",
      "language": "zh"
    },
    {
      "provision_ref": "2",
      "chapter": "",
      "section": "2",
      "title": "",
      "content": "凡国旗和区旗同时或者并列升挂、使用时，国旗应当大于区旗，国旗在右，区旗在左。",
      "language": "zh"
    },
    {
      "provision_ref": "3",
      "chapter": "",
      "section": "3",
      "title": "",
      "content": "列队举持国旗和区旗行进时，国旗应当在区旗之前。",
      "language": "zh"
    }
  ],
  "definitions": [],
  "eu_references": []
}