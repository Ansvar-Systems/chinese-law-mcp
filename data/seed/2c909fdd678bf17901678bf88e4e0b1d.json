{
  "id": "2c909fdd678bf17901678bf88e4e0b1d",
  "type": "statute",
  "title": "中华人民共和国烟叶税法",
  "title_en": "",
  "short_name": "",
  "status": "in_force",
  "issued_date": "2017-12-27",
  "in_force_date": "2018-07-01",
  "url": "https://flk.npc.gov.cn/detail?bbbs=2c909fdd678bf17901678bf88e4e0b1d",
  "category_code": 140,
  "category_name": "经济法 (Economic)",
  "issuing_body": "全国人民代表大会常务委员会",
  "provisions": [
    {
      "provision_ref": "1",
      "chapter": "",
      "section": "1",
      "title": "",
      "content": "在中华人民共和国境内，依照《中华人民共和国烟草专卖法》的规定收购烟叶的单位为烟叶税的纳税人。纳税人应当依照本法规定缴纳烟叶税。",
      "language": "zh"
    },
    {
      "provision_ref": "2",
      "chapter": "",
      "section": "2",
      "title": "",
      "content": "本法所称烟叶，是指烤烟叶、晾晒烟叶。",
      "language": "zh"
    },
    {
      "provision_ref": "3",
      "chapter": "",
      "section": "3",
      "title": "",
      "content": "烟叶税的计税依据为纳税人收购烟叶实际支付的价款总额。",
      "language": "zh"
    },
    {
      "provision_ref": "4",
      "chapter": "",
      "section": "4",
      "title": "",
      "content": "烟叶税的税率为百分之二十。",
      "language": "zh"
    },
    {
      "provision_ref": "5",
      "chapter": "",
      "section": "5",
      "title": "",
      "content": "烟叶税的应纳税额按照纳税人收购烟叶实际支付的价款总额乘以税率计算。",
      "language": "zh"
    },
    {
      "provision_ref": "6",
      "chapter": "",
      "section": "6",
      "title": "",
      "content": "烟叶税由税务机关依照本法和《中华人民共和国税收征收管理法》的有关规定征收管理。",
      "language": "zh"
    },
    {
      "provision_ref": "7",
      "chapter": "",
      "section": "7",
      "title": "",
      "content": "纳税人应当向烟叶收购地的主管税务机关申报缴纳烟叶税。",
      "language": "zh"
    },
    {
      "provision_ref": "8",
      "chapter": "",
      "section": "8",
      "title": "",
      "content": "烟叶税的纳税义务发生时间为纳税人收购烟叶的当日。",
      "language": "zh"
    },
    {
      "provision_ref": "9",
      "chapter": "",
      "section": "9",
      "title": "",
      "content": "烟叶税按月计征，纳税人应当于纳税义务发生月终了之日起十五日内申报并缴纳税款。",
      "language": "zh"
    },
    {
      "provision_ref": "10",
      "chapter": "",
      "section": "10",
      "title": "",
      "content": "本法自2018年7月1日起施行。2006年4月28日国务院公布的《中华人民共和国烟叶税暂行条例》同时废止。",
      "language": "zh"
    }
  ],
  "definitions": [],
  "eu_references": []
}